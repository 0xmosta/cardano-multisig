CARDANO_NETWORK=preprod
VITE_CARDANO_NETWORK=preprod

# PostgreSQL-backed server state (accounts, sessions, relay rooms). Required for
# production-like preprod/mainnet deploys. Local file storage remains available in
# development when DATABASE_URL is unset or CARDANO_MULTISIG_ALLOW_FILE_STORE=1.
DATABASE_URL=
MIGRATION_DATABASE_URL=
CARDANO_MULTISIG_ALLOW_FILE_STORE=0
CARDANO_MULTISIG_SESSION_SECRET=
# Optional dedicated at-rest encryption key. When omitted, the session secret is
# used. Keep previous values comma-separated during key rotation.
CARDANO_MULTISIG_DATA_ENCRYPTION_SECRET=
CARDANO_MULTISIG_DATA_ENCRYPTION_SECRET_PREVIOUS=
CARDANO_MULTISIG_RATE_LIMIT_SECRET=
CARDANO_MULTISIG_COOKIE_SECURE=
CARDANO_MULTISIG_PUBLIC_ORIGIN=

# Optional Web Push keys for opt-in background progress notifications. Generate
# a VAPID keypair outside the repository and keep the private key server-side.
CARDANO_MULTISIG_VAPID_PUBLIC_KEY=
CARDANO_MULTISIG_VAPID_PRIVATE_KEY=
CARDANO_MULTISIG_VAPID_SUBJECT=

# Server-side only. Do not expose this value in browser code, logs, Kanban
# comments, or completion summaries.
BLOCKFROST_URL=https://cardano-preprod.blockfrost.io/api/v0
BLOCKFROST_PROJECT_ID=

# Optional self-hosted provider overrides.
CARDANO_KUPO_URL=
CARDANO_OGMIOS_URL=
CARDANO_SUBMIT_URL=
