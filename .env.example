CARDANO_NETWORK=preprod
VITE_CARDANO_NETWORK=preprod

# PostgreSQL-backed server state (accounts, sessions, relay rooms). Required for
# production-like preprod/mainnet deploys. Local file storage remains available in
# development when DATABASE_URL is unset or CARDANO_MULTISIG_ALLOW_FILE_STORE=1.
DATABASE_URL=
MIGRATION_DATABASE_URL=
CARDANO_MULTISIG_ALLOW_FILE_STORE=0
CARDANO_MULTISIG_SESSION_SECRET=

# Server-side only. Do not expose this value in browser code, logs, Kanban
# comments, or completion summaries.
BLOCKFROST_URL=https://cardano-preprod.blockfrost.io/api/v0
BLOCKFROST_PROJECT_ID=

# Optional self-hosted provider overrides.
CARDANO_KUPO_URL=
CARDANO_OGMIOS_URL=
CARDANO_SUBMIT_URL=
